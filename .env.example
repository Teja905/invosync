# MongoDB
MONGODB_URI=mongodb://mongodb:27017/invoice_tally
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=secure_password

# AI Keys
OPENROUTER_API_KEY=sk-or-v1-your-key
GEMINI_API_KEY=your-gemini-key

# Company Defaults
COMPANY_NAME=My Firm
COMPANY_GSTIN=27AABCU1234F1ZP
COMPANY_STATE_CODE=27

# Tally
TALLY_PASSWORD=
TALLY_PORT=9000

# Object Storage (S3/R2) — images go here instead of MongoDB
# Leave empty to use local filesystem (./storage/) for development.
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=invosync-invoices
S3_ENDPOINT=
S3_REGION=auto
